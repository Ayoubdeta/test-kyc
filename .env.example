# ─── Copia este archivo a ".env" y ajusta los valores ───
# NUNCA subas el .env real al control de versiones (ya está en .gitignore).

# PostgreSQL
POSTGRES_USER=kyc_user
POSTGRES_PASSWORD=cambia_esta_password
POSTGRES_DB=kyc_db
POSTGRES_PORT=5432

# Backend
NODE_ENV=development
BACKEND_PORT=4000

# Secretos JWT: genera valores largos y aleatorios, por ejemplo con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=genera_un_secreto_largo_aleatorio_para_access
JWT_REFRESH_SECRET=genera_otro_secreto_largo_aleatorio_para_refresh

# Vida del access token (formato de "ms"/jsonwebtoken: 15m, 1h, etc.)
ACCESS_TOKEN_TTL=15m
# Vida del refresh token, en días
REFRESH_TOKEN_TTL_DAYS=7

# Coste del hash bcrypt (10-12 es un buen equilibrio seguridad/rendimiento)
BCRYPT_SALT_ROUNDS=12

# Origen permitido por CORS (URL del frontend en desarrollo)
CORS_ORIGIN=http://localhost:5173

# Cookies "Secure" (solo HTTPS). En desarrollo por HTTP debe ser false; en producción, true.
COOKIE_SECURE=false

# Tamaño máximo por documento PDF subido, en MB.
# NOTA: en la demo serverless de Vercel (Hobby) el límite de payload por
# petición es ~4,5 MB, así que en producción usa 4.
MAX_UPLOAD_MB=10

# Administrador inicial (lo crea el script de seed: npm run seed:admin).
ADMIN_EMAIL=admin@kyc.local
ADMIN_PASSWORD=Admin_Local_2026
ADMIN_USERNAME=admin

# ─────────────────────────────────────────────────────────────────────
# DESPLIEGUE EN VERCEL + SUPABASE (demo). No aplican en Docker local.
# Ver DEPLOY.md para el paso a paso.
# ─────────────────────────────────────────────────────────────────────
# Conexión a PostgreSQL de Supabase (Connection Pooler, modo Transaction,
# puerto 6543). Si está presente, tiene prioridad sobre las variables PG*.
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
#
# Supabase Storage (almacenamiento de PDFs y adjuntos del chat):
# SUPABASE_URL=https://<ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service_role_key>   # ¡SECRETO! solo en el servidor
# SUPABASE_BUCKET=kyc-files
#
# Tiempo real del chat por SSE. En Vercel (serverless) ponlo en 'false'
# (el chat usará polling). En local puede quedarse sin definir (activo).
# ENABLE_SSE=false
