# Config del backend para ejecución LOCAL (fuera de Docker).
# Copia a ".env". Cuando corre dentro de docker-compose, estas
# variables las inyecta el propio compose (ver docker-compose.yml).

NODE_ENV=development
PORT=4000

# Conexión a PostgreSQL. Si la base de datos corre en Docker con el
# puerto publicado, desde tu máquina el host es localhost.
PGHOST=localhost
PGPORT=5432
PGUSER=kyc_user
PGPASSWORD=cambia_esta_password
PGDATABASE=kyc_db

JWT_ACCESS_SECRET=genera_un_secreto_largo_aleatorio_para_access
JWT_REFRESH_SECRET=genera_otro_secreto_largo_aleatorio_para_refresh
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7
BCRYPT_SALT_ROUNDS=12

CORS_ORIGIN=http://localhost:5173
COOKIE_SECURE=false

# Carpeta de subidas de PDF y tamaño máximo por fichero (MB).
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10

# Administrador inicial para el seed (npm run seed:admin).
ADMIN_EMAIL=admin@kyc.local
ADMIN_PASSWORD=Admin_Local_2026
ADMIN_USERNAME=admin
